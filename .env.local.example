# ============================================================
# AI Portfolio Dashboard — 環境変数テンプレート
# ============================================================
# このファイルを .env.local にコピーして値を設定してください。
# .env.local は .gitignore で除外されており、Gitにはコミットされません。
#
# cp .env.local.example .env.local
# ============================================================

# ── Anthropic Claude API ─────────────────────────────────────
# https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── 株価 API（Alpha Vantage）────────────────────────────────
# https://www.alphavantage.co/support/#api-key
VITE_STOCK_API_KEY=xxxxxxxxxxxx

# ── Supabase（クラウド同期・マルチデバイス対応）─────────────────
# https://supabase.com/dashboard → プロジェクト → Settings → API
# 未設定の場合はローカルファイル同期（data/portfolio.json）で動作します。
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx
